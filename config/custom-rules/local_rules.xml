<!--
  Wazuh Lab — custom rules (student-facing)

  IDs 100100–100179. Each rule is described in terms of what it
  *literally matches* — a regex, a field value, a decoded substring.
  The descriptions do not name the attack class each rule represents;
  mapping them to CVEs and MITRE techniques is part of Lab 3.

  Severity levels are a starting point. Several are deliberately
  conservative; raising them (and adding correlation rules) is part of
  Lab 3.
-->

<group name="wazuh-lab,">

  <rule id="100120" level="12">
    <if_sid>31100</if_sid>
    <regex>\.%2e/|/%2e\.</regex>
    <description>HTTP request: url contains an encoded '..' segment — Path Traversal attempt</description>
    <group>attack,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100175" level="7">
    <if_sid>31105</if_sid>
    <description>HTTP request: url contains a scripting expression pattern</description>
    <mitre>
      <id>T1059.007</id>
    </mitre>
  </rule>

  <rule id="100130" level="13">
    <match>jndi:</match>
    <description>Log4Shell: JNDI lookup detected — CVE-2021-44228 RCE attempt</description>
    <group>attack,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100155" level="15" frequency="2" timeframe="120">
    <if_matched_sid>100130</if_matched_sid>
    <if_matched_sid>100150</if_matched_sid>
    <description>CRITICAL: Log4Shell RCE confirmed — /etc/passwd modified after JNDI lookup within 120s</description>
    <group>attack,critical,</group>
    <mitre>
      <id>T1190</id>
      <id>T1136.001</id>
    </mitre>
  </rule>

  <rule id="100140" level="13">
    <match>pkexec</match>
    <description>Pwnkit: pkexec privilege escalation detected — CVE-2021-4034</description>
    <group>attack,</group>
    <mitre>
      <id>T1068</id>
    </mitre>
  </rule>

  <rule id="100150" level="15">
    <if_sid>550,554</if_sid>
    <field name="file">/etc/passwd</field>
    <description>FIM: /etc/passwd modified — possible backdoor account created</description>
    <group>attack,</group>
    <mitre>
      <id>T1136.001</id>
    </mitre>
  </rule>

  <rule id="100165" level="3">
    <decoded_as>corpnet-login</decoded_as>
    <match>result=failure</match>
    <description>CorpNet Portal: login failed for user $(dstuser)</description>
  </rule>

  <rule id="100166" level="5">
    <decoded_as>corpnet-login</decoded_as>
    <match>result=success</match>
    <description>CorpNet Portal: login succeeded for user $(dstuser)</description>
  </rule>

  <rule id="100163" level="3">
    <if_sid>31101</if_sid>
    <url>/login</url>
    <description>HTTP: POST /login — authentication failed</description>
  </rule>

  <rule id="100164" level="5">
    <if_sid>31108</if_sid>
    <match>POST /login</match>
    <description>HTTP: POST /login — authentication successful</description>
  </rule>

  <rule id="100162" level="7">
    <if_sid>31108</if_sid>
    <match>POST /reports/submit/</match>
    <description>Apache: POST to /reports/submit/ — possible Heartbleed exfil staging</description>
    <group>attack,</group>
    <mitre>
      <id>T1071.001</id>
    </mitre>
  </rule>

  <rule id="100160" level="3">
    <if_sid>554</if_sid>
    <field name="file">/var/lib/reports/</field>
    <description>FIM: new file under /var/lib/reports/</description>
  </rule>

  <rule id="100170" level="13">
    <match>tar</match>
    <description>Exfiltration staging: tar invoked — possible data archiving for exfil</description>
    <group>attack,</group>
    <mitre>
      <id>T1560.001</id>
    </mitre>
  </rule>

  <rule id="100171" level="15" frequency="2" timeframe="120">
    <if_matched_sid>100162</if_matched_sid>
    <if_matched_sid>100170</if_matched_sid>
    <description>Exfiltration detected: report submission followed by tar archiving within 120s</description>
    <group>attack,</group>
    <mitre>
      <id>T1041</id>
    </mitre>
  </rule>

  <!-- Suppress benign noise -->
  <rule id="100300" level="0">
    <if_sid>19007</if_sid>
    <description>Suppress: CIS Benchmark check — benign, fires on startup</description>
  </rule>

  <rule id="100301" level="0">
    <if_sid>19004</if_sid>
    <description>Suppress: SCA summary CIS — low score expected on lab machine</description>
  </rule>

  <rule id="100302" level="0">
    <if_sid>19008</if_sid>
    <description>Suppress: CIS Benchmark check — benign, fires on startup</description>
  </rule>

  <rule id="100303" level="0">
    <if_sid>19009</if_sid>
    <description>Suppress: CIS Benchmark check — benign, fires on startup</description>
  </rule>

</group>
